# Copy this file to .env and fill in the values before running the container.
# NEVER commit .env to source control.

# Passphrase used to encrypt the LUKS1 volume.
LUKS_PASSWORD=

# Password for the root account on the installed system.
ROOT_PASSWORD=

# Password for the regular user account on the installed system.
USER_PASSWORD=

# XBPS repository used for both image build and install steps.
VOID_XBPS_REPOSITORY=https://repo-default.voidlinux.org/current
